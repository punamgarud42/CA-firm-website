# Database (PostgreSQL via Supabase)
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@YOUR_SUPABASE_HOST.supabase.co:5432/postgres"

# NextAuth v5
AUTH_SECRET="your-super-secret-key-generate-with-openssl"
AUTH_URL="http://localhost:3000"

# Google OAuth
AUTH_GOOGLE_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# Supabase (for file storage and realtime)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"

# App Config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="TaxPro CA Firm"

# Email (Resend)
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="noreply@yourcafirm.com"

# OpenAI (for AI Assistant)
OPENAI_API_KEY="sk_your_openai_api_key"

# PostHog Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY="your-posthog-key"
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
